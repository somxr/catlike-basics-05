#pragma kernel TorusPulseToTorusSpiralKernel
#pragma kernel TorusPulseKernel
#pragma kernel TorusPulseToTorusCentrifugeKernel

#pragma kernel TorusCentrifugeToSphereKernel
#pragma kernel TorusCentrifugeToTorusKernel
